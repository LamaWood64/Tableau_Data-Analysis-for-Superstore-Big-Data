      <aliases enabled='yes' />
      <column caption='Avg profit per order' datatype='real' name='[Calculation_0282506943840258]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / COUNTD([Order ID])' />
      </column>
      <column caption='Avg Profit per Order' datatype='real' name='[Calculation_0282507346333699]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / COUNTD([Order ID])' />
      </column>
      <column caption='Sales and profit correlation' datatype='real' name='[Calculation_0282507700342789]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SCRIPT_REAL(&#10;&quot;&#10;import numpy as np&#10;&#10;if len(_arg1) &lt; 2:&#10;    return [None] * len(_arg1)&#10;&#10;corr = np.corrcoef(_arg1, _arg2)[0,1]&#10;&#10;return [corr] * len(_arg1)&#10;&quot;,&#10;ATTR([Sales]),&#10;ATTR([Profit])&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sales per cust' datatype='real' name='[Calculation_0282507708329998]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Customer Name] : SUM([Sales]) }' />
      </column>
      <column caption='Profit per cust ' datatype='real' name='[Calculation_0282507708809232]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Customer Name] : SUM([Profit]) }' />
      </column>
      <column caption='Sales-Profit Correlation' datatype='real' name='[Calculation_0282507711049745]' role='measure' type='quantitative'>
